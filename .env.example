# ---------- Cosmo configuration ----------

# MOCK_MODE=1 means: simulated on-chain payments, no wallet needed, public
# demo works with zero further config. Recommended for the public deploy.
# Set to "" or remove to enable real on-chain spending (requires funded wallet).
MOCK_MODE=1

# Devnet by default. Switch to "mainnet-beta" only when ready for live.
SOLANA_CLUSTER=devnet

# Cosmo's wallet, base58-encoded private key.
# Required only when MOCK_MODE is unset. Generate via: npm run fund
COSMO_PRIVATE_KEY=

# Where Cosmo sends payment to (the "API provider" address).
# Required only when MOCK_MODE is unset.
PAYMENT_RECIPIENT=

# Per-call payment amount in lamports. 1 SOL = 1,000,000,000 lamports.
# Default: 0.001 SOL per paid call.
PAYMENT_LAMPORTS=1000000

# Server port. Railway/Render/Fly inject their own PORT — leave blank in
# production. For local dev, defaults to 4019.
PORT=4019
